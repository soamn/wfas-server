// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkflowState {
  Scheduled
  Draft
  Inactive
  Running
  Completed
}

enum NodeType {
  ACTION
  MANUAL_API
  SET
  FILTER
  DELAY
  CHAT
  TRANSFORM
  EXTRACT
  CONDITION
  LOOP
  SWITCH
  FAIL
  WEBHOOK
  PARALLEL
  MERGE
  TRIGGER
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  isActive    Boolean
  workflows   Workflow[]
  credentials Credential[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @updatedAt
}

model Credential {
  id         Int    @id @default(autoincrement())
  userId     Int
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String @unique
  credential Json
}

model Workflow {
  id            String         @id @default(cuid())
  name          String?
  description   String?
  userId        Int
  state         WorkflowState
  nodes         Node[]
  connections   Connection[]
  executionLogs ExecutionLog[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime?      @updatedAt
}

model Node {
  id         String       @id @default(cuid())
  workflowId String
  type       NodeType
  label      String?
  status     String?      @default("idle")
  position   Json?
  result     Json?
  error      String?
  index      Int
  outgoing   Connection[] @relation("SourceNode")
  incoming   Connection[] @relation("TargetNode")
  config     Json?
  workflow   Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Connection {
  id           Int      @id @default(autoincrement())
  workflowId   String
  sourceNodeId String
  targetNodeId String
  sourceHandle String?
  targetHandle String?
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode   Node     @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   Node     @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
}

model ExecutionLog {
  id         Int       @id @default(autoincrement())
  workflowId String
  startedAt  DateTime
  endTime    DateTime?
  status     String
  resultData Json?
  error      Json?
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}
